{
  "name": "afromessage-unofficial-ts",
  "version": "0.1.0",
  "description": "Unofficial TypeScript SDK for the AfroMessage SMS & OTP API",
  "author": "Estifanos",
  "license": "MIT",
  "keywords": [
    "afromessage",
    "sms",
    "otp",
    "ethiopia",
    "typescript",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estifanosbereket1/afromessage-sdk-unofficial.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm typecheck && pnpm test",
    "postbuild": "cp dist/index.d.ts dist/index.d.cts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "msw": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
